{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for students and teachers.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "displayName", "email", "role"]
    },
    "Classroom": {
      "title": "Classroom",
      "description": "A group where teachers and students interact.",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "inviteCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classId", "name", "teacherId", "inviteCode"]
    },
    "Question": {
      "title": "Q&A Question",
      "description": "An anonymous or signed question asked in a classroom.",
      "type": "object",
      "properties": {
        "questionId": { "type": "string" },
        "classId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "upvotes": { "type": "number" },
        "answered": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["questionId", "classId", "authorId", "content"]
    },
    "Poll": {
      "title": "Classroom Poll",
      "description": "A quick pulse check poll created by the teacher.",
      "type": "object",
      "properties": {
        "pollId": { "type": "string" },
        "classId": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pollId", "classId", "question", "options"]
    },
    "PollResponse": {
      "title": "Poll Response",
      "description": "A student's answer to a poll.",
      "type": "object",
      "properties": {
        "responseId": { "type": "string" },
        "pollId": { "type": "string" },
        "studentId": { "type": "string" },
        "optionIndex": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["responseId", "pollId", "studentId", "optionIndex"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "Alerts for new questions, poll updates, or shared resources.",
      "type": "object",
      "properties": {
        "notificationId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["new_question", "poll_update", "resource_shared", "system"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "classId": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["notificationId", "userId", "type", "title", "message", "read"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "General discussion message within a classroom.",
      "type": "object",
      "properties": {
        "messageId": { "type": "string" },
        "classId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["messageId", "classId", "authorId", "content"]
    },
    "Resource": {
      "title": "Classroom Resource",
      "description": "Educational materials shared by the teacher.",
      "type": "object",
      "properties": {
        "resourceId": { "type": "string" },
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["link", "document", "video", "other"] },
        "url": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["resourceId", "classId", "title", "url", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User-specific alerts and updates."
    },
    "/classrooms/{classId}": {
      "schema": "Classroom",
      "description": "Classroom metadata."
    },
    "/classrooms/{classId}/members/{userId}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "Membership mapping for classrooms."
    },
    "/classrooms/{classId}/questions/{questionId}": {
      "schema": "Question",
      "description": "Questions in a classroom."
    },
    "/classrooms/{classId}/polls/{pollId}": {
      "schema": "Poll",
      "description": "Polls in a classroom."
    },
    "/classrooms/{classId}/polls/{pollId}/responses/{userId}": {
      "schema": "PollResponse",
      "description": "User responses to a specific poll."
    },
    "/classrooms/{classId}/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "General discussion messages."
    },
    "/classrooms/{classId}/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Shared educational materials."
    }
  }
}
