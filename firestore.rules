rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Helper to check classroom membership - avoid too many get() or exists() in list rules
    function isMember(classId) {
      return isSignedIn() && exists(/databases/$(database)/documents/classrooms/$(classId)/members/$(request.auth.uid));
    }

    // Helper to check if user is the teacher of a classroom
    function isTeacher(classId) {
      // Use get() to check teacherId on the classroom doc
      return isSignedIn() && exists(/databases/$(database)/documents/classrooms/$(classId)) && 
             get(/databases/$(database)/documents/classrooms/$(classId)).data.teacherId == request.auth.uid;
    }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == userId &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email == request.auth.token.email &&
               data.role in ['student', 'teacher'] &&
               data.createdAt == request.time;
      }

      allow get: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'role']) &&
                    (incoming().displayName is string && incoming().displayName.size() <= 100);
    }

    // 1.1 Notifications
    match /users/{userId}/notifications/{notificationId} {
      function isValidNotification(data) {
        return data.notificationId == notificationId &&
               data.userId == userId &&
               data.type in ['new_question', 'poll_update', 'resource_shared', 'system'] &&
               data.read == false &&
               data.createdAt == request.time;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId) && resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(userId);
      allow create: if isSignedIn() && isValidNotification(incoming());
    }

    // 2. Classrooms
    match /classrooms/{classId} {
      function isValidClassroom(data) {
        return data.classId == classId &&
               data.name is string && data.name.size() <= 100 &&
               data.teacherId == request.auth.uid &&
               data.inviteCode is string && data.inviteCode.size() <= 10 &&
               data.createdAt == request.time;
      }

      allow create: if isSignedIn() && isValidClassroom(incoming()) && isValidId(classId);
      allow get: if isMember(classId) || isTeacher(classId);
      allow list: if isSignedIn(); 

      allow update: if isTeacher(classId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description']) &&
                    incoming().name is string && incoming().name.size() <= 100;
    }

    // 3. Membership
    match /classrooms/{classId}/members/{userId} {
      allow get: if isMember(classId) || isTeacher(classId);
      allow list: if (isMember(classId) || isTeacher(classId)) && (resource.data.userId == request.auth.uid || isTeacher(classId));
      allow create: if isOwner(userId);
    }

    // 4. Questions
    match /classrooms/{classId}/questions/{questionId} {
      function isValidQuestion(data) {
        return data.questionId == questionId &&
               data.classId == classId &&
               data.authorId == request.auth.uid &&
               data.content is string && data.content.size() <= 1000 &&
               data.isAnonymous is bool &&
               data.upvotes == 0 &&
               data.answered == false &&
               data.createdAt == request.time;
      }

      allow get: if isMember(classId) || isTeacher(classId);
      allow list: if isMember(classId) || isTeacher(classId);
      allow create: if isMember(classId) && isValidQuestion(incoming()) && isValidId(questionId);
      
      allow update: if (isMember(classId) || isTeacher(classId)) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['upvotes']) && incoming().upvotes == existing().upvotes + 1) ||
        (isTeacher(classId) && incoming().diff(existing()).affectedKeys().hasOnly(['answered']))
      );
    }

    // 5. Polls
    match /classrooms/{classId}/polls/{pollId} {
      function isValidPoll(data) {
        return data.pollId == pollId &&
               data.classId == classId &&
               data.question is string && data.question.size() <= 500 &&
               data.options is list && data.options.size() >= 2 && data.options.size() <= 10 &&
               data.active == true &&
               data.createdAt == request.time;
      }

      allow get: if isMember(classId) || isTeacher(classId);
      allow list: if isMember(classId) || isTeacher(classId);
      allow create: if isTeacher(classId) && isValidPoll(incoming()) && isValidId(pollId);
      allow update: if isTeacher(classId) && incoming().diff(existing()).affectedKeys().hasOnly(['active']);
    }

    // 6. Poll Responses
    match /classrooms/{classId}/polls/{pollId}/responses/{userId} {
      function isValidResponse(data) {
        return data.pollId == pollId &&
               data.studentId == request.auth.uid &&
               data.optionIndex is int &&
               data.createdAt == request.time;
      }

      allow get: if isTeacher(classId) || isOwner(userId);
      allow list: if isTeacher(classId) || isOwner(userId);
      allow create: if isMember(classId) && isOwner(userId) && isValidResponse(incoming());
    }

    // 7. Chat Messages
    match /classrooms/{classId}/chat_messages/{messageId} {
      function isValidChatMessage(data) {
        return data.messageId == messageId &&
               data.classId == classId &&
               data.authorId == request.auth.uid &&
               data.content is string && data.content.size() <= 2000 &&
               data.createdAt == request.time;
      }
      allow get: if isMember(classId) || isTeacher(classId);
      allow list: if isMember(classId) || isTeacher(classId);
      allow create: if (isMember(classId) || isTeacher(classId)) && isValidChatMessage(incoming());
    }

    // 8. Resources
    match /classrooms/{classId}/resources/{resourceId} {
      function isValidResource(data) {
        return data.resourceId == resourceId &&
               data.classId == classId &&
               data.title is string && data.title.size() <= 200 &&
               data.url is string && data.url.size() <= 1000 &&
               data.type in ['link', 'document', 'video', 'other'] &&
               data.createdAt == request.time;
      }
      allow get: if isMember(classId) || isTeacher(classId);
      allow list: if isMember(classId) || isTeacher(classId);
      allow create, delete: if isTeacher(classId) && isValidResource(incoming());
      allow update: if isTeacher(classId) && isValidResource(incoming());
    }
  }
}
